<div class="measurement-row">
    <div class="xps_plot">
        {{ measurement.script }}
        {{ measurement.div }}
    </div>

    <div class="table_column">
        <table style:"width=100%">
            <tr>
                <th>File ID</th>
                <td><a href="file:///{{ measurement.fileinfo.filepath }}">{{ measurement.m_id() }}</a></td>
            </tr>
            <tr>
                <th>Datetime</th>
                <td>{{ measurement.datetime().strftime("%Y-%m-%d") }} <br> {{ measurement.datetime().strftime("%H:%M:%S") }}</td>
            </tr>
            <tr>
                <th>Controller </th>
                <td>{{ measurement.controller }}</td>
            </tr>
            <tr>
                <th>EC type</th>
                <td>{{ measurement.ec_type}}</td>
            </tr>
            {% if measurement.controller == 'LabView' %}
                {% if measurement.timestep is not none %}
                    <tr>
                        <th>Timestep</th>
                        <td>{{ "{:.0f}".format(measurement.timestep) }} ms</td>
                    </tr>
                {% endif %}
                {% if measurement.scanrate is not none %}
                    <tr>
                        <th>Scanrate</th>
                        <td>{{ "{:.0f}".format(measurement.scanrate) }} mV/s</td>
                    </tr>
                {% endif %}
            {% endif %}
        </table>
    </div>

    <div class="table_column">
        <table style:"width=100%">
            <tr>
                <th></th>
                <td>&nbsp;</td>
            </tr>
            {% if measurement.ec_type == 'Cyclic Voltammetry' %}
                {% if measurement.u_start is defined and measurement.u_start is not none %}
                    <tr>
                        <th>E<sub>WE_start</sub></th>
                        <td>{{ "%.3f"|format(measurement.u_start) }} V</td>
                    </tr>
                    <tr>
                        <th>E<sub>WE_1</sub> / E<sub>WE_2</sub></th>
                        <td>{{ "%.3f"|format(measurement.u_1) }} / {{ "%.3f"|format(measurement.u_2) }} V</td>
                    </tr>
                    <tr>
                        <th>ΔE<sub>WE</sub></th>
                        <td>{{ "%.3f"|format((measurement.u_2 - measurement.u_1) | abs) }} V</td>
                    </tr>
                {% endif %}    
                {% if measurement.ub_start is defined and measurement.ub_start is not none and measurement.datetime().timestamp() > 1765843200 %}
                    <tr>
                        <th></th>
                        <td>&nbsp;</td>
                    </tr>
                    <tr>
                        <th>U<sub>b_start</sub></th>
                        <td>{{ "%.3f"|format(measurement.ub_start) }} V</td>
                    </tr>
                    <tr>
                        <th>U<sub>b_1</sub> / U<sub>b_</sub></th>
                        <td>{{ "%.3f"|format(measurement.ub_1) }} / {{ "%.3f"|format(measurement.ub_2) }} V</td>
                    </tr>
                    <tr>
                        <th>ΔU<sub>b</sub></th>
                        <td>{{ "%.3f"|format((measurement.ub_2 - measurement.ub_1) | abs) }} V</td>
                    </tr>
                {% endif %}
            {% endif %}
            {% if measurement.ec_type == 'Chronoamperometry' %}
                {% if measurement.u_start is defined and measurement.u_start is not none %}
                    <tr>
                        <th>E<sub>WE_start</sub></th>
                        <td>{{ "%.3f"|format(measurement.u_start) }} V</td>
                    </tr>
                    <tr>
                        <th>E<sub>WE_max</sub> / E<sub>WE_min</sub></th>
                        <td>{{ "%.3f"|format(measurement.u_2) }} / {{ "%.3f"|format(measurement.u_1) }} V</td>
                    </tr>
                    <tr>
                        <th>ΔE<sub>WE</sub></th>
                        <td>{{ "%.3f"|format(measurement.u_2 - measurement.u_1) }} V</td>
                    </tr>
                {% endif %}    
                {% if measurement.ub_start is defined and measurement.ub_start is not none and measurement.datetime().timestamp() > 1765843200 %}
                    <tr>
                        <th></th>
                        <td>&nbsp;</td>
                    </tr>
                    <tr>
                        <th>U<sub>b_start</sub></th>
                        <td>{{ "%.3f"|format(measurement.ub_start) }} V</td>
                    </tr>
                    <tr>
                        <th>U<sub>b_max</sub> / U<sub>b_min</sub></th>
                        <td>{{ "%.3f"|format(measurement.ub_2) }} / {{ "%.3f"|format(measurement.ub_1) }} V</td>
                    </tr>
                    <tr>
                        <th>ΔU<sub>b</sub></th>
                        <td>{{ "%.3f"|format(measurement.ub_2 - measurement.ub_1) }} V</td>
                    </tr>
                {% endif %}
            {% endif %}
        </table>
    </div>
</div>
